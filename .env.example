# ============================================
# Meta Threads API Configuration
# ============================================

# Threads 액세스 토큰 (Meta Developer Portal에서 발급)
# https://developers.facebook.com/docs/threads/get-started
THREADS_ACCESS_TOKEN=your_access_token_here

# Threads 사용자 ID (숫자)
THREADS_USER_ID=your_user_id_here

# 다중 계정 설정 (JSON 포맷 배열, 토큰과 사용자 ID만 지정하여 간편하게 등록할 수 있습니다)
# 예: THREADS_MULTI_ACCOUNTS='[{"userId":"123","accessToken":"token1"},{"userId":"456","accessToken":"token2"}]'
THREADS_MULTI_ACCOUNTS='[]'

# ============================================
# API Settings
# ============================================

# Threads Graph API 기본 URL
THREADS_API_BASE_URL=https://graph.threads.net/v1.0

# 미디어 컨테이너 게시 전 대기 시간 (밀리초) - Meta 권장: 30초
PUBLISH_WAIT_MS=30000
